{
  "manifest_version": 3,
  "name": "Mini UniKey Hybrid",
  "version": "3.6.0",
  "description": "Gõ Telex trực tiếp trên web với raw-word buffer để xử lý đúng hoàn tác dấu ngay trong editor.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mini UniKey Hybrid"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "engine.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}